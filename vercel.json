{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://dew.up.railway.app/api/$1"
    },
    { "handle": "filesystem" },
    {
      "src": "^/$",
      "dest": "/landing.html"
    },
    {
      "src": "^/(?:community(?:/.*)?$|profile(?:/.*)?$|dashboard(?:/.*)?$)",
      "dest": "/index.html"
    },
    {
      "src": "/.*",
      "dest": "/404.html"
    }
  ]
}
