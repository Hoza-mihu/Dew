# DEW Eco Warden – copy to .env and fill in your values
# Get these from Firebase Console → Project settings → Your apps → Web app config

PORT=3000

FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=1:your-sender-id:web:your-app-id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase (for profile photo storage) – from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# OpenWeather (optional – for dashboard weather). If set, used instead of Open-Meteo. Get key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Vite local dev proxy target (frontend dev server -> backend API)
VITE_DEV_API_TARGET=http://localhost:3000

# --- Plant Bot / telemetry (Python script: scripts/telemetry_sender.py) ---
# Preferred: device token — auto-created when you open the dashboard (Plant Fleet → device token). Paste once into .env or ESP32.
# DEW_INGEST_TOKEN=dew_xxxxxxxx...
# Legacy: Firebase user id string in JSON "uid" (if you do not use ingest token).
# DEW_UID=your-firebase-uid

# --- Server dev only (NOT for plant bot, NOT for “users without Firebase”) ---
# If the Node server has no Firebase Admin credentials, weather GET/PUT /api/users/:uid/location
# would otherwise return 503. Set DEW_ALLOW_UNAUTH_LOCATION=1 only on local machines for testing.
# Production: use FIREBASE_SERVICE_ACCOUNT_JSON (or GOOGLE_APPLICATION_CREDENTIALS) instead—never set this in prod.
# DEW_ALLOW_UNAUTH_LOCATION=1
